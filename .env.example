# Copy to .env and adjust. Shared by both compose variants:
#   docker-compose.prod.yml  — Variant 1: TLS on host/NAS, API serves HTTP
#   docker-compose.tls.yml   — Variant 2: TLS in-stack via Caddy (self-signed / Let's Encrypt)

# ── Common (both variants) ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me
JWT_SECRET=change-me-too
DJANGO_DEBUG=false
# Released image tag to deploy (e.g. 0.1.0, latest).
API_TAG=latest

# Public hostname. Auto-added to the API's ALLOWED_HOSTS + CSRF. In Variant 2
# it is also the certificate's domain. Use localhost for a local self-signed test.
DOMAIN=localhost
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CSRF_TRUSTED_ORIGINS=

JWT_TTL_SECONDS=900
CHALLENGE_TTL_SECONDS=300

POSTGRES_DB=meteorpointer
POSTGRES_USER=meteorpointer
POSTGRES_PASSWORD=meteorpointer

# ── Variant 1 only — TLS on host/NAS (docker-compose.prod.yml) ───────────────
# Optional hardening: bind the API only to the host so just the host proxy
# reaches it (default is 0.0.0.0:8000).
# API_BIND=127.0.0.1:8000

# ── Variant 2 only — in-stack HTTPS (docker-compose.tls.yml) ─────────────────
# Certificate mode:
#   empty    -> Caddy self-signed CA (local test, e.g. DOMAIN=localhost)
#   an email -> Let's Encrypt, auto-obtained and auto-renewed (real DOMAIN)
ACME_EMAIL=
# Bind the proxy to a specific host IP if :443 is already taken, e.g.:
# PROXY_HTTP=192.168.0.49:80
# PROXY_HTTPS=192.168.0.49:443
